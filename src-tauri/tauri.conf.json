{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "minimal-explorer",
  "version": "1.0.0",
  "identifier": "com.minimalexplorer.dev",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk0NEZBOTBDNzFFODAyQTYKUldTbUF1aHhES2xQbEwzNlU5S00xWkFWV0xSU3ZhWkVJRmhobVdEUUc2Ky96NzJ3RnFQVmIraXIK",
      "endpoints": [  
        "https://github.com/deminimis/MinimalExplorer/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "windows": [
      {
        "title": "minimal-explorer",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost thumbnail: http://thumbnail.localhost icon: http://icon.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installerHooks": "hooks.nsi",
        "installerIcon": "icons/icon.ico"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
